<!--
  YCL启动器 — 亮色主题
  页面纯白背景，UI/图标为深海蓝
-->
<resources>
    <style name="Theme.YCLLauncher" parent="android:Theme.Material.Light.NoActionBar">
        <!-- 状态栏 -->
